# Supabase — get these from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Server
PORT=3001
NODE_ENV=development

# Admin protection — choose strong values
ADMIN_USER=admin
ADMIN_PASS=change-this-to-something-strong

# Ingest protection — random string
INGEST_SECRET=change-this-to-random-string

# Error tracking — get free DSN from sentry.io
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Alerts
ALERT_EMAIL=byron@nurserymatch.com

# Reviews — secret used to hash submitter IPs (rate limit + dedupe)
REVIEW_IP_SECRET=change-this-to-random-string

# PropertyData.co.uk — live market stats (asking price, rents, yields, demand, growth)
PROPERTYDATA_API_KEY=your-propertydata-api-key-here

# Anthropic Claude API — powers AI summary, review synthesis, smart search
ANTHROPIC_API_KEY=your-key-here

# Resend transactional email — get key from resend.com
RESEND_API_KEY=re_xxx
EMAIL_FROM=NurseryMatch <hello@nurserymatch.com>
# Resend audience ID for the newsletter signup form (Marketing → Audiences
# in the Resend dashboard). Optional; signup endpoint queues silently when
# unset so the frontend keeps working.
RESEND_AUDIENCE_ID=

# Cloudflare Turnstile — spam protection on enquiry endpoint. Optional;
# leave blank to disable verification (middleware no-ops without it).
# Pair with NEXT_PUBLIC_TURNSTILE_SITE_KEY on the frontend.
TURNSTILE_SECRET_KEY=


# Google Places API (New) — nursery ratings, reviews, photos
GOOGLE_PLACES_API_KEY=your-google-api-key-here

# Google Search Console — organic search clicks/impressions for the analytics
# dashboards (provider + admin). Optional: the dashboards hide the Google figures
# when these are unset. The refresh token MUST be authorised for the
# https://www.googleapis.com/auth/webmasters.readonly scope.
# GSC_SITE_URL must match exactly how the property is verified, e.g.
#   sc-domain:nurserymatch.com        (Domain property)
#   https://nurserymatch.com/         (URL-prefix property)
GSC_SITE_URL=
# Client id/secret fall back to the GOOGLE_ADS_* values when left blank.
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# Travel time — OSRM public demo is used by default; override to self-host
# OSRM_URL=https://router.project-osrm.org

# Stripe — billing + subscriptions
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PROVIDER_PRO=price_...
STRIPE_PRICE_PROVIDER_PREMIUM=price_...
STRIPE_PRICE_PARENT_PREMIUM=price_...

# Buffer — social media scheduling (Marketing Hub)
# Personal API key for Buffer's GraphQL API (https://developers.buffer.com).
# Sent as a Bearer token. The classic v1 REST API is not used.
BUFFER_API_TOKEN=
# Optional — pin a specific organization. If blank, the first organization on
# the account is used automatically.
BUFFER_ORGANIZATION_ID=

# Marketing autopilot — auto-generate + queue a social post Mon/Wed/Fri 09:00 UTC
# to drive acquisition. Off by default; set "true" to enable the recurring job.
# Needs ANTHROPIC_API_KEY + BUFFER_API_TOKEN and at least one connected channel.
MARKETING_AUTOPILOT_ENABLED=false
# Optional default image (public JPG/PNG) used for image-first networks like
# Instagram in autopilot posts. Without it, Instagram is skipped.
MARKETING_DEFAULT_IMAGE_URL=

# Google Ads — campaign management (Marketing Hub)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
