# API — local development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase — same values as backend (anon key only — never put service key here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps — enables Street View on nursery profiles
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-api-key-here

# Sentry — optional, leave blank to disable
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Turnstile — spam protection on enquiry form. Optional;
# leave blank to disable (frontend + backend both no-op without keys).
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Bing Webmaster Tools — site verification meta tag. Get the value from
# bing.com/webmasters when you add the site. Optional; renders nothing
# when unset.
NEXT_PUBLIC_BING_VERIFICATION=

# Plausible Analytics — cookieless, GDPR-compliant. Set to your domain
# (e.g. nurserymatch.com). Optional; no analytics script loaded when unset.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Ads — conversion tracking. Get your AW-XXXXXXXXX ID from
# Google Ads > Tools > Conversions. Optional; no gtag loaded when unset.
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google AdSense — display ads for revenue. Get your ca-pub-XXXXXXXXX
# publisher ID from adsense.google.com. Optional; no ads shown when unset.
NEXT_PUBLIC_ADSENSE_ID=

# Meta Pixel (Facebook/Instagram retargeting). Get pixel ID from
# Meta Events Manager. Optional; no pixel loaded when unset.
NEXT_PUBLIC_META_PIXEL_ID=

# Google Remarketing tag. Uses the same gtag.js as Google Ads.
# Set to your AW- or DC- ID. Optional.
NEXT_PUBLIC_GOOGLE_REMARKETING_ID=
