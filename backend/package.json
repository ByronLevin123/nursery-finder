{
  "name": "nurserymatch-api",
  "version": "1.0.0",
  "description": "NurseryMatch backend API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/worker.js",
    "worker:dev": "nodemon src/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@sentry/node": "^7.91.0",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.19.0",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "resend": "^4.8.0",
    "stripe": "^22.0.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.0.0",
    "pino-pretty": "^10.3.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "vitest": "^2.1.1"
  }
}
