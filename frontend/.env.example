# API — local development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase — same values as backend (anon key only — never put service key here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps — enables Street View on nursery profiles
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-api-key-here

# Sentry — optional, leave blank to disable
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Turnstile — spam protection on enquiry form. Optional;
# leave blank to disable (frontend + backend both no-op without keys).
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Bing Webmaster Tools — site verification meta tag. Get the value from
# bing.com/webmasters when you add the site. Optional; renders nothing
# when unset.
NEXT_PUBLIC_BING_VERIFICATION=
